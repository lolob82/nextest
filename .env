# NatureMama Heritage Configuration
# Simple configuration for your e-commerce website

# API Configuration
# Replace with your actual API Gateway URL after deployment
VITE_API_ENDPOINT=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/prod/orders

# Email Configuration
# Your verified email address in Amazon SES
VITE_FROM_EMAIL=orders@naturemama.com

# Website Configuration
VITE_WEBSITE_NAME=NatureMama Heritage
VITE_WEBSITE_URL=https://your-website-domain.com

# AWS Region (do not change)
VITE_AWS_REGION=us-east-1